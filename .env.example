# AI Provider: "anthropic" or "azure"
AI_PROVIDER=azure

# Anthropic (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Azure OpenAI (required if AI_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure AD Service Principal
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Fabric Warehouse
FABRIC_SERVER=
FABRIC_DATABASE=gold_warehouse
FABRIC_SCHEMA=ownd

# Gmail
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=gmail_token.json

# Logging
LOG_FILE=eod_processor.log

# SMTP Notification
SMTP_SERVER=
SMTP_PORT=25
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=EOD Processor
# Comma-separated for multiple recipients
SMTP_TO_SUCCESS=
SMTP_TO_ERROR=
